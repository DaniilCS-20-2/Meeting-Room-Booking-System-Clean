DATABASE_URL=postgresql://ferma_app:YOUR_STRONG_DB_PASS@localhost:5432/booking_app_db
# Минимум 32 символа, случайные. В production пустой/дефолтный секрет отклоняется.
JWT_SECRET=please-generate-at-least-32-random-characters-xxxxxx
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:5173
# Через запятую. Нужен, если фронт живёт ещё и на другом домене/порту.
ALLOWED_ORIGINS=
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
ADMIN_EMAILS=admin@example.com,another-admin@example.com
